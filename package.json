{
  "name": "cotrackpro-voice-center",
  "version": "1.0.0",
  "description": "CoTrackPro AI Voice Contact Center — Twilio + ElevenLabs + Anthropic MCP",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "node --import tsx --test tests/*.test.ts",
    "generate-audio": "tsx scripts/generate-prerecorded.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@aws-sdk/client-dynamodb": "^3.1032.0",
    "@aws-sdk/lib-dynamodb": "^3.1032.0",
    "@clerk/backend": "^3.2.13",
    "@fastify/formbody": "^8.0.2",
    "@fastify/websocket": "^11.0.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "twilio": "^5.4.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  }
}
