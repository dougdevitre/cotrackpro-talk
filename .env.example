# ─────────────────────────────────────────────────────────────────────
# CoTrackPro Voice Center — .env.example
# ─────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the values you need. Variables
# marked REQUIRED will cause the server to fail-fast on startup if
# unset. Variables marked OPTIONAL have safe defaults.
#
# Two deployment shapes are supported:
#   1. Single host → set SERVER_DOMAIN only
#   2. Hybrid (Vercel HTTP + long-running WS host) → set API_DOMAIN + WS_DOMAIN
# See README.md "Deployment options" for details.
#
# ─────────────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────────────
# Port the Fastify server binds to. OPTIONAL (default 8080).
PORT=8080

# NODE_ENV drives a few safety behaviors:
#   - disables pino-pretty
#   - makes CRON_SECRET required instead of warn-on-missing
# OPTIONAL (default "development"); set to "production" in prod.
NODE_ENV=development

# Log level. OPTIONAL (default "info"). Use "debug" when triaging.
LOG_LEVEL=info

# Domains. Pick ONE of the two patterns:
#
#   (a) Single-host: set SERVER_DOMAIN only. Both HTTP and WS serve
#       from the same origin. Example: ngrok, a VPS, one Fargate task.
SERVER_DOMAIN=your-domain.ngrok-free.app
#
#   (b) Hybrid: set API_DOMAIN (Vercel) and WS_DOMAIN (long-running
#       host). In this mode SERVER_DOMAIN can be unset.
# API_DOMAIN=api.example.com
# WS_DOMAIN=ws.example.com

# ── Twilio ──────────────────────────────────────────────────────────
# REQUIRED. Account SID, auth token, and the voice-enabled number
# that CoTrackPro calls originate from.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15551234567

# A2P 10DLC Messaging Service SID. Outbound SMS is sent THROUGH this so
# every message is attributed to the approved brand/campaign. REQUIRED in
# production (src/core/sms.ts refuses to send without it); when unset
# locally, sends fall back to TWILIO_PHONE_NUMBER for testing.
# Mirrored from SSM /cotrackpro/<stage>/twilio/messaging_service_sid.
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Validate the X-Twilio-Signature on inbound webhooks. OPTIONAL
# (default "false"). Set to "true" in any deployment that receives
# real Twilio traffic — required for production.
VALIDATE_TWILIO_SIGNATURE=false

# ── ElevenLabs (TTS + STT) ──────────────────────────────────────────
# REQUIRED.
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Model ID for TTS. OPTIONAL (default eleven_flash_v2_5 — fastest
# TTFB, best for real-time voice).
ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# Named ElevenLabs voice for the "Doug" persona. OPTIONAL.
# Mirrored from SSM /cotrackpro/<stage>/elevenlabs/voice_id_doug.
ELEVENLABS_VOICE_ID_DOUG=

# Voice map override: JSON object mapping CoTrackPro role →
# ElevenLabs voice ID. OPTIONAL; if unset, src/config/voices.ts
# defaults are used.
# VOICE_MAP={"parent":"voice_id_1","attorney":"voice_id_2"}

# Per-phone-number override for inbound calls. JSON object keyed by
# E.164 phone number → { voiceId, role }. /call/incoming uses the
# Twilio "To" number to look up an entry; when matched, both the
# ElevenLabs voice and the persona are pinned for the call. Leave
# unset to fall back to the ?role= query param + getVoiceId(role).
# Canonical source: SSM at /cotrackpro/prod/voice/inbound_phone_map.
# INBOUND_PHONE_VOICE_MAP={"+13143948500":{"voiceId":"2ydcbtd5sJZRYFMNgMVZ","role":"parent"}}

# ── Anthropic ───────────────────────────────────────────────────────
# REQUIRED.
ANTHROPIC_API_KEY=sk-ant-api-xxxxxxxxxxxxxxxxxxxxxxxxx

# Claude model ID. OPTIONAL (default claude-sonnet-4-20250514).
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── CoTrackPro MCP (documentation tool calls) ───────────────────────
# OPTIONAL (default https://mcp.cotrackpro.com/sse). Point at a
# local MCP server during dev.
COTRACKPRO_MCP_URL=https://mcp.cotrackpro.com/sse

# ── Outbound API auth + shared hub↔talk bearer ──────────────────────
# Bearer token required on POST /call/outbound and every /records/*
# endpoint. This is ALSO the shared hub↔talk secret: the talk edge
# presents it on calls TO the hub (resolve-phone, send-auth-link) and
# verifies it (constant-time) on calls FROM the hub (/api/sms/send).
# Leave unset to DISABLE auth (local dev only — never in production).
#
# Source from SSM: /cotrackpro/<stage>/talk/outbound_api_key, mirrored
# into Vercel as TALK_OUTBOUND_API_KEY by scripts/sync-ssm-to-vercel.sh.
# The legacy OUTBOUND_API_KEY name is still honored as a fallback.
TALK_OUTBOUND_API_KEY=
# OUTBOUND_API_KEY=  # deprecated alias for TALK_OUTBOUND_API_KEY

# Sliding-window rate limits on POST /call/outbound. Override if
# the defaults (30/min, 500/hr per API key) don't fit your traffic.
OUTBOUND_RATE_LIMIT_PER_MIN=30
OUTBOUND_RATE_LIMIT_PER_HOUR=500

# ── CoTrackPro hub (identity / OTP / token minting) ─────────────────
# Base URL of the hub's Lambda Function URL / custom domain, per stage.
# Inbound calls resolve the caller's number to a Clerk subject here, and
# unlinked callers are texted a one-time sign-in link. Leave unset to
# DISABLE hub integration (every caller is treated as anonymous; crisis
# resources + anonymous help still work). No trailing slash.
HUB_BASE_URL=
# Per-call timeout (ms). Kept short so a slow hub can't stall Twilio's
# inbound webhook.
HUB_TIMEOUT_MS=4000

# ── SMS send (hub → talk: POST /api/sms/send) ───────────────────────
# Rate limits on the inbound SMS-send endpoint the hub calls to deliver
# composed messages (incl. sign-in links) through our Twilio number.
SMS_RATE_LIMIT_PER_MIN=30
SMS_RATE_LIMIT_PER_HOUR=500

# ── Outbound voice (hub → talk: POST /api/call/outbound) ────────────
# Hard per-UTC-day cap on one-shot Doug's-voice reminder calls, on top of
# the per-min/per-hour outbound limits. Set to 0 to disable.
CALL_DAILY_CAP=50
# TTL (seconds) on the KV pointer holding a pending voice line between
# placing the call and Twilio fetching the <Play> audio.
VOICE_LINE_TTL_SECONDS=3600
# Voice-consent gate. When "true", /api/call/outbound refuses (403) any
# request that doesn't attest `consent: true` — the hub must assert it
# captured explicit VOICE consent (TCPA, distinct from SMS opt-in).
# Defaults ON in production when unset; set explicitly here for clarity.
REQUIRE_VOICE_CONSENT=true

# Rate limits on /records/* (see E-1 in the audit). Typical dashboard
# traffic is low but a leaked key could amplify into unbounded
# DynamoDB scans. Defaults err on the safe side.
RECORDS_RATE_LIMIT_PER_MIN=120
RECORDS_RATE_LIMIT_PER_HOUR=2000

# Per-user rate limits on POST /api/ai/complete. Budget is keyed on Clerk
# userId and shared across every sub-app the user touches. Tune based on
# expected sub-app traffic; defaults err on the safe side.
AI_RATE_LIMIT_PER_MIN=20
AI_RATE_LIMIT_PER_HOUR=300

# Phone number allow-list for POST /call/outbound. Comma-separated
# ISO-3166 country codes. Defaults to "US,CA" which matches the
# operational target. Use "*" to allow any E.164 number (NOT
# recommended — removes bill-fraud protection).
OUTBOUND_ALLOWED_COUNTRY_CODES=US,CA

# ── Concurrent-call cap ─────────────────────────────────────────────
# Hard ceiling on simultaneous WS sessions on a single WS host. New
# sessions beyond this return a "server busy" TwiML and are rejected
# BEFORE any downstream STT/Claude/TTS resource is allocated.
# Raise carefully — each session holds ~20KB of per-call state plus
# its open Anthropic stream + ElevenLabs WS.
MAX_CONCURRENT_SESSIONS=200

# ── DynamoDB (call records) ─────────────────────────────────────────
# OPTIONAL. Set DYNAMO_ENABLED=true to persist call records. When
# disabled the app runs without any AWS dependency — useful for
# local dev.
DYNAMO_ENABLED=false
DYNAMO_TABLE_NAME=cotrackpro-calls
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY are picked up from the
# standard AWS credential chain — no need to set them here unless
# you're running outside an IAM role.

# Retention for call records. OPTIONAL (default 365 days). Accepts
# fractional days for testing (e.g. "0.04" = ~1 hour).
RECORDS_TTL_DAYS=365

# Max retries the DynamoDB client attempts before a write fails
# permanently. OPTIONAL (default 3). Increase if you see throttling
# under load; decrease if latency during DynamoDB outages is hurting
# call quality more than missing records would.
DYNAMO_MAX_RETRIES=3

# ── KV store (rate limits, idempotency cache, cross-instance state) ─
# OPTIONAL. Leave all three unset for single-process in-memory
# backend (fine for single-host; rate-limit counters and idempotency
# replays are per-instance). Set the three KV_* vars to use an
# Upstash Redis REST endpoint or Vercel KV (API-compatible) so state
# is shared across Vercel functions and the long-running WS host.
#
# KV_BACKEND values: "auto" (default — uses upstash when
# KV_URL/KV_TOKEN are set), "memory", "upstash", or "dynamo".
KV_BACKEND=auto
# KV_URL=https://<region>-<name>-<id>.upstash.io
# KV_TOKEN=your-upstash-rest-token
#
# AWS-native alternative (no Upstash): set KV_BACKEND=dynamo and point at
# a DynamoDB table with partition key "pk" (String) and TTL enabled on the
# "expireAt" attribute. Uses AWS_REGION + the standard AWS credential
# chain. Works from Vercel serverless (HTTP, no VPC). Distinct from the
# call-records table (DYNAMO_TABLE_NAME).
# KV_DYNAMO_TABLE=cotrackpro-kv

# ── External-service timeouts (audit E-5) ───────────────────────────
# Explicit timeouts on the audio hot path so a slow upstream doesn't
# deadlock a call for 2 hours. Values in milliseconds.
ANTHROPIC_STREAM_TIMEOUT_MS=45000
ELEVENLABS_CONNECT_TIMEOUT_MS=10000

# ── Vercel Cron (daily cost rollup) ─────────────────────────────────
# REQUIRED when NODE_ENV=production. Shared secret Vercel Cron sends
# as a Bearer token to /api/cron/cost-rollup. In non-production
# environments the handler logs a warning and allows unauthenticated
# calls (local-dev escape hatch). In production the handler now
# FAILS CLOSED if this is unset (audit E-3).
CRON_SECRET=

# ── Clerk (federated auth from CoTrackPro sub-apps) ─────────────────
# OPTIONAL. Set both to accept Clerk-issued JWTs on user-facing routes
# (/call/outbound, /records/*) in addition to OUTBOUND_API_KEY. When
# unset, the code silently skips JWT verification and only API-key
# auth is honored. Source from SSM:
#   /cotrackpro/prod/auth/clerk/publishable_key
#   /cotrackpro/prod/auth/clerk/secret_key
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ── Admin dashboard ─────────────────────────────────────────────────
# OPTIONAL. Separate API key for the dashboard. If unset, the
# dashboard UI reuses OUTBOUND_API_KEY. Set this only when you want
# a distinct credential (e.g. read-only operator accounts).
DASHBOARD_API_KEY=

# ── Pricing overrides (cost estimator) ──────────────────────────────
# All OPTIONAL. Change these as Anthropic / ElevenLabs pricing
# changes — no redeploy needed. Units: USD per million tokens for
# Claude, USD per 1K chars for ElevenLabs TTS, USD per minute for
# ElevenLabs STT.
CLAUDE_INPUT_PRICE_PER_MTOK=3.00
CLAUDE_OUTPUT_PRICE_PER_MTOK=15.00
CLAUDE_CACHE_WRITE_PRICE_PER_MTOK=3.75
CLAUDE_CACHE_READ_PRICE_PER_MTOK=0.30
ELEVENLABS_TTS_PRICE_PER_1K_CHARS=0.10
ELEVENLABS_STT_PRICE_PER_MIN=0.008
